# Build stage
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json vite.config.js index.html ./
RUN npm ci
COPY src ./src
RUN npm run build

# Serve stage
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
